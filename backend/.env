# RoomTint Backend — Environment Variables
# ─────────────────────────────────────────
# PostgreSQL connection (local)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/roomtint

# Disable HuggingFace telemetry
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
HF_HUB_OFFLINE=1

# Point HF to local cache (won't be used after download_models.py)
TRANSFORMERS_CACHE=./models
